# Base URL da API Spot (trinity/analytics). Multi-tenant: todas as chamadas usam companyId.
# Em dev, se VITE_USE_API_PROXY não for "false", as chamadas usam /api (proxy Vite) para evitar CORS.
VITE_SPOT_API_BASE_URL=https://spot-api-management.o2obots.com

# Em dev: "false" desativa o proxy (usa URL absoluta; exige CORS no backend).
# VITE_USE_API_PROXY=false

# CompanyId usado quando ainda não há autenticação. Depois virá do token (contexto de auth).
VITE_DEFAULT_COMPANY_ID=316


# Gatekeeper (partition): URLs que não usam rewrite por companyId. Lista separada por vírgula.
# VITE_SPOT_SKIP_GATEKEEPER_URLS=/morpheus/foo

# Quando gatekeeper da empresa é morpheus e a URL está em SKIP, usar esta base.
# VITE_SPOT_API_MORPHEUS_URL=https://morpheus.example.com
