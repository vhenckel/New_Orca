# Base URL da API Spot (trinity/analytics). Multi-tenant: todas as chamadas usam companyId.
VITE_SPOT_API_BASE_URL=https://spot-api-management.o2obots.com

# CompanyId usado quando ainda não há autenticação. Depois virá do token (contexto de auth).
VITE_DEFAULT_COMPANY_ID=316

# Token temporário para testes. Copie do browser (cookies ou header Authorization) e cole aqui. Depois virá do login.
VITE_SPOT_API_TOKEN=
